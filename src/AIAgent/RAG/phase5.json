{
    "$defs": {
        "MemoryOperation": {
            "description": "对一个结构化记忆键执行更新或删除。",
            "properties": {
                "action": {
                    "enum": [
                        "upsert",
                        "delete"
                    ],
                    "title": "Action",
                    "type": "string"
                },
                "category": {
                    "enum": [
                        "identity",
                        "preference",
                        "constraint",
                        "decision",
                        "pending_task",
                        "fact"
                    ],
                    "title": "Category",
                    "type": "string"
                },
                "key": {
                    "description": "稳定的英文键，例如 user.name 或 response.style",
                    "maxLength": 80,
                    "minLength": 1,
                    "pattern": "^[a-z][a-z0-9_.-]*$",
                    "title": "Key",
                    "type": "string"
                },
                "value": {
                    "anyOf": [
                        {
                            "maxLength": 300,
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "title": "Value"
                }
            },
            "required": [
                "action",
                "category",
                "key"
            ],
            "title": "MemoryOperation",
            "type": "object"
        }
    },
    "description": "一次批量抽取的结构化操作。",
    "properties": {
        "operations": {
            "items": {
                "$ref": "#/$defs/MemoryOperation"
            },
            "maxItems": 10,
            "title": "Operations",
            "type": "array"
        }
    },
    "title": "MemoryExtraction",
    "type": "object"
}